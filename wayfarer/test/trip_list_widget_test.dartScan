import 'package:flutter/material.dart';
import 'package:flutter_test/flutter_test.dart';
import 'package:provider/provider.dart';
import 'package:wayfarer/screens/trip_planner/trip_planner_screen.dart';
import 'package:wayfarer/providers/trip_provider.dart';
import 'package:shared_preferences/shared_preferences.dart';

void main() {
  setUp(() {
    SharedPreferences.setMockInitialValues({});
  });

  testWidgets('TripPlannerScreen displays empty state or list', (WidgetTester tester) async {
    await tester.pumpWidget(
      MaterialApp(
        home: ChangeNotifierProvider(
          create: (_) => TripProvider(),
          child: const TripPlannerScreen(),
        ),
      ),
    );

    expect(find.text('My Trips'), findsOneWidget);
    expect(find.byType(FloatingActionButton), findsOneWidget);
  });
}
